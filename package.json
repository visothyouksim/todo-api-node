{
  "name": "express-crud-todo",
  "version": "1.0.0",
  "description": "a todo api",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "test": "jest --testEnvironment=node",
    "test:coverage": "jest --testEnvironment=node --coverage"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.17.1",
    "helmet": "^7.1.0",
    "sql.js": "^1.6.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "branches": 70
      }
    },
    "testPathIgnorePatterns": ["/node_modules/"]
  }
}
